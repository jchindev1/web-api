{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Web API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/web-api.web/bin/Debug/net9.0/web-api.web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/web-api.web",
            "console": "internalConsole",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": "Launch Web API (HTTP)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/web-api.web/bin/Debug/net9.0/web-api.web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/web-api.web",
            "console": "internalConsole",
            "stopAtEntry": false,
            "launchBrowser": {
                "enabled": true,
                "args": "${auto-detect-url}/weatherforecast",
                "windows": {
                    "command": "cmd.exe",
                    "args": "/C start ${auto-detect-url}/weatherforecast"
                }
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5113"
            }
        },
        {
            "name": "Launch Web API (HTTPS)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/web-api.web/bin/Debug/net9.0/web-api.web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/web-api.web",
            "console": "internalConsole",
            "stopAtEntry": false,
            "launchBrowser": {
                "enabled": true,
                "args": "${auto-detect-url}/weatherforecast",
                "windows": {
                    "command": "cmd.exe",
                    "args": "/C start ${auto-detect-url}/weatherforecast"
                }
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:7259;http://localhost:5113"
            }
        },
        {
            "name": "Attach to Web API",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}"
        }
    ]
}
